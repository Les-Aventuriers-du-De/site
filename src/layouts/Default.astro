---
import Address from "../components/_/Address.astro";
import Email from "../components/_/Email.astro";
import MainMenu from "../components/_/MainMenu.astro";
import Footer from "../components/Footer.astro";
import FooterCard from "../components/FooterCard.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Link from "../components/Link.astro";
import SecondaryMenu from "../components/SecondaryMenu.astro";
import SecondaryMenuItem from "../components/SecondaryMenuItem.astro";
import SkipLink from "../components/SkipLink.astro";
import SkipLinks from "../components/SkipLinks.astro";
import ToggleTheme from "../components/ToggleTheme.astro";
import { Config } from "../Config";
import BaseLayout from "./Base.astro";

type Props = {
  lang?: "fr";
  siteTitle?: string;
  siteTagline?: string;
  pageTitle: string;
  pageDescription?: string;
  pageIllustrationUrl?: string;
};
const {
  lang = "fr",
  siteTitle = Config.site.title,
  siteTagline = Config.site.tagline,
  pageTitle,
  pageDescription,
  pageIllustrationUrl,
} = Astro.props;
---

<BaseLayout {lang} {siteTitle} {pageTitle} {pageDescription}>
  <slot slot="head" name="head" />
  <script slot="head" type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Les Aventuriers du Dé",
      "url": "https://les-aventuriers-du-de.github.io/",
      "email": "les-aventuriers-du-de@outlook.fr",
      "description": "Association loi 1901 de jeux de société, jeux de cartes et jeux de rôles à Mérignac.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "25 rue Paul Langevin",
        "postalCode": "33700",
        "addressLocality": "Mérignac",
        "addressCountry": "FR"
      }
    }
  </script>
  <slot name="skip-links">
    <SkipLinks>
      <SkipLink href="#contenu">Aller au contenu</SkipLink>
      <SkipLink href="#menu-principal">Aller au menu principal</SkipLink>
      <SkipLink href="#pied-de-page">Aller au pied de page</SkipLink>
    </SkipLinks>
  </slot>
  <slot name="header">
    <Header>
      <Fragment slot="title">{siteTitle}</Fragment>
      <Fragment slot="tagline">{siteTagline}</Fragment>
      <Fragment slot="main-tools">
        <slot name="main-tools" />
      </Fragment>
      <Fragment slot="secondary-tools">
        <ToggleTheme />
        <slot name="secondary-menu" />
      </Fragment>
      <Fragment slot="before-menu">
        <slot name="before-menu" />
      </Fragment>
      <Fragment slot="after-menu">
        <slot name="after-menu" />
      </Fragment>
      <slot name="main-menu" slot="menu">
        <MainMenu />
      </slot>
    </Header>
  </slot>
  <main id="contenu">
    <!-- transition:animate="slide" -->
    <slot name="hero">
      <Hero mode="banner" illustrationUrl={pageIllustrationUrl}>
        <Fragment slot="title">{pageTitle}</Fragment>
        <Fragment slot="description">
          <slot name="description">
            {pageDescription}
          </slot>
        </Fragment>
        <slot name="illustration" slot="illustration" />
      </Hero>
    </slot>
    <slot />
  </main>
  <slot name="footer">
    <Footer>
      <FooterCard wide>
        <p><strong>Les Aventuriers du Dé</strong></p>
        <p>Association loi 1901 dédiée aux jeux de société.</p>
      </FooterCard>
      <!-- <PlanFooterCard /> -->
      <FooterCard>
        <p><strong>Contact</strong></p>
        <Email />
        <Address />
        <p>
          <Link href="/contact" appearance="button">Formulaire de contact</Link>
        </p>
      </FooterCard>
      <slot name="copyright" slot="copyright">
        <p>
          &copy; {new Date().getFullYear()} Les Aventuriers du Dé. Tous droits réservés.
        </p>
      </slot>
      <slot name="ternary-menu" slot="menu">
        <SecondaryMenu>
          <SecondaryMenuItem href="/à-propos">À propos</SecondaryMenuItem>
          <SecondaryMenuItem href="/mentions-légales">
            Mentions légales
          </SecondaryMenuItem>
          <SecondaryMenuItem href="/confidentialité">
            Confidentialité
          </SecondaryMenuItem>
          <SecondaryMenuItem href="/accessibilité">
            Accessibilité
          </SecondaryMenuItem>
          <SecondaryMenuItem href="/statuts"> Statuts </SecondaryMenuItem>
          <SecondaryMenuItem href="/règlement-intérieur">
            Règlement intérieur
          </SecondaryMenuItem>
        </SecondaryMenu>
      </slot>
    </Footer>
  </slot>
</BaseLayout>
