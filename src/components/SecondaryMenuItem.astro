---
const { href } = Astro.props;

const pathname = decodeURIComponent(Astro.url.pathname);
const current =
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(`${href}/`);
---

<li class="menu__item">
  <a {href} aria-current={current ? "page" : undefined}>
    <slot />
  </a>
</li>
