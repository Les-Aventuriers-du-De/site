---
type Props = {
  width?: "wide" | "narrow";
};
const { width } = Astro.props;
---

<section class:list={["section", width ? `section--${width}` : undefined]}>
  <div class="section__content">
    <div class="section__content-inner">
      <slot />
    </div>
    {
      Astro.slots.aside && (
        <aside class="section__aside">
          <slot name="aside" />
        </aside>
      )
    }
  </div>
</section>

<style lang="scss">
  @use "../responsive" as *;
  .section {
    margin-block: 2rem;
  }
  .section__content {
    display: grid;
    gap: 2rem;
    grid-auto-flow: row;
  }
  .section__content-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .section__aside {
    display: grid;
    grid-auto-flow: row;
    grid-template-columns: repeat(auto-fit, minmax(40%, 1fr));
    gap: 2rem;
    @include from(lg) {
      display: flex;
      flex-direction: column;
    }
  }
  @include from(lg) {
    .section__content {
      &:has(.section__aside) {
        grid-template-columns:
          minmax(clamp(0px, calc(75% - 2rem), 936px), 3fr)
          minmax(clamp(220px, calc(25% - 2rem), 312px), 1fr);
      }
    }
  }
</style>
