---
import { isEnabled } from "../../config/features";
import Menu from "../Menu.astro";
import MenuItem from "../MenuItem.astro";
---

<Menu id="menu-principal" slot="menu">
  <MenuItem href="/">L'association</MenuItem>
  {isEnabled("pages", "blog") && <MenuItem href="/blog">Actualités</MenuItem>}
  {
    isEnabled("pages", "events") && (
      <MenuItem href="/événements">Événements</MenuItem>
    )
  }
  {
    isEnabled("pages", "games") && (
      <MenuItem href="/ludothèque">Ludothèque</MenuItem>
    )
  }
  <MenuItem href="/contact">Contact</MenuItem>
</Menu>
