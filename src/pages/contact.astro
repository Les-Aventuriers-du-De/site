---
import Address from "../components/_/Address.astro";
import Card from "../components/Card.astro";
import Section from "../components/Section.astro";
import { Config } from "../Config";
import DefaultLayout from "../layouts/Default.astro";
import Email from "../components/_/Email.astro";

const title = "Contact";
---

<DefaultLayout siteTitle={Config.site.title} pageTitle={title}>
  <Fragment slot="description">
    Une question&nbsp;? Une suggestion&nbsp;? N'hésitez pas à nous écrire&nbsp;!
  </Fragment>

  <Section>
    <!-- Left column -->
    <Card id="formulaire" compact>
      <Fragment slot="title"> Envoyez-nous un Message </Fragment>
      <p class="form-intro">
        Remplissez le formulaire ci-dessous et nous vous répondrons dans les
        plus brefs délais.
      </p>

      <form class="contact-form" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="first_name">Prénom *</label>
            <input
              type="text"
              id="first_name"
              name="first_name"
              placeholder="Ton prénom"
              required
            />
            <p class="field-error">
              Ton prénom nous permet de mieux te connaître.
            </p>
          </div>
          <div class="form-group">
            <label for="last_name">Nom *</label>
            <input
              type="text"
              id="last_name"
              name="last_name"
              placeholder="Ton nom"
            />
          </div>
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="Ton adresse email"
            required
          />
          <p class="field-error">
            Ton adresse email nous permet de te répondre.
          </p>
        </div>

        <div class="form-group">
          <label for="phone">Téléphone</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="Ton numéro de téléphone"
          />
        </div>

        <div class="form-group">
          <label for="subject">Sujet *</label>
          <select
            id="subject"
            name="subject"
            aria-placeholder="Sélectionnez un sujet"
            required
          >
            <option value="" selected disabled>Sélectionnez un sujet</option>
            <option value="info">Demande d'information</option>
            <option value="membership">Adhésion</option>
            <option value="event">Question sur un événement</option>
            <option value="partnership">Partenariat</option>
            <option value="other">Autre</option>
          </select>
          <p class="field-error">
            Pourquoi tu veux nous contacter&nbsp;! C'est important.
          </p>
        </div>

        <div class="form-group">
          <label for="message">Message *</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder="Ton message"
            required></textarea>
          <p class="field-error">
            Ton message est obligatoire. On veut savoir ce que tu as à nous
            dire&nbsp;!
          </p>
        </div>

        <button type="submit" class="btn btn-primary">
          Envoyer le Message
        </button>
        <script is:inline>
          document.addEventListener("DOMContentLoaded", () => {
            const form = document.querySelector(".contact-form");
            form?.addEventListener("submit", (event) => {
              if (!form.checkValidity()) {
                event.preventDefault();
              }
            });
          });
        </script>

        <p class="form-notice">* Champs obligatoires</p>
      </form>
    </Card>

    <!-- Right column -->
    <Fragment slot="aside">
      <Card id="adresse" compact>
        <Fragment slot="title">
          <i class="ri-map-pin-line"></i> Adresse
        </Fragment>
        <Address />
      </Card>
      <Card id="info" compact>
        <Fragment slot="title">
          <i class="ri-mail-line"></i> Email
        </Fragment>
        <Email />
      </Card>
      <Card id="carte" compact>
        <Fragment slot="title">
          <i class="ri-map-2-line"></i> Plan d'Accès
        </Fragment>
        <div class="map-placeholder">
          <p>Carte à venir</p>
        </div>
      </Card>
    </Fragment>
  </Section>
</DefaultLayout>

<style>
  .contact-form .btn {
    width: 100%;
    padding: 1rem;
    font-size: 1rem;
    margin-top: 1rem;
  }
</style>
