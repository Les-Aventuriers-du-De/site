---
import { getCollection } from "astro:content";
import Section from "../components/Section.astro";
import DefaultLayout from "../layouts/Default.astro";

const page = "Crédits des illustrations";

const allCredits = await getCollection("credits");
const allCreditsGroupedByPage = allCredits.reduce(
  (acc, credit) => {
    const page = credit.data.page;
    if (!acc[page]) {
      acc[page] = [];
    }
    acc[page].push(credit);
    return acc;
  },
  {} as Record<string, typeof allCredits>,
);
---

<DefaultLayout
  pageTitle={page}
  pageDescription="Crédits des illustrations utilisées sur le site"
>
  <Fragment slot="description">
    Sources et auteurs des photographies utilisées sur le site.
  </Fragment>
  <Section>
    <p>
      Cette page recense l'origine des photographies utilisées sur le site. Ces
      informations sont également présentes directement dans le code de chaque
      image (attributs data-credit-*), sans être visibles à l'écran ni annoncées
      par un lecteur d'écran.
    </p>
    {
      Object.entries(allCreditsGroupedByPage).map(([page, creditsForPage]) => (
        <section>
          <h2>Page d'{page}&nbsp;</h2>
          <ul>
            {creditsForPage.map((credits) => (
              <article>
                <h3>
                  Photo de&nbsp;:
                  <a href={credits.data.authorUrl}>{credits.data.author}</a>
                </h3>
                <p>
                  Source&nbsp;:
                  <a href={credits.data.sourceUrl}>{credits.data.source}</a>•
                  License&nbsp;: {credits.data.license}
                </p>
              </article>
            ))}
          </ul>
        </section>
      ))
    }
  </Section>
</DefaultLayout>
